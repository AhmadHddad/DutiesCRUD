{
  "openapi": "3.0.3",
  "info": {
    "title": "Nexplore Duties API",
    "version": "1.0.0",
    "description": "HTTP API for the shared duties application."
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local backend"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Service health endpoints."
    },
    {
      "name": "Duties",
      "description": "CRUD endpoints for shared duties."
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Check backend and database health",
        "responses": {
          "200": {
            "description": "Service and database are healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Database check failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/duties": {
      "get": {
        "tags": [
          "Duties"
        ],
        "summary": "List duties",
        "parameters": [
          {
            "$ref": "#/components/parameters/XRequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Offset"
          },
          {
            "$ref": "#/components/parameters/DutyNameFilter"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated duty list.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/XRequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DutyListPageEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Duties"
        ],
        "summary": "Create a duty",
        "parameters": [
          {
            "$ref": "#/components/parameters/XRequestIdHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DutyInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created duty.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/XRequestId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DutyEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Invalid duty input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Write rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/duties/{id}": {
      "get": {
        "tags": [
          "Duties"
        ],
        "summary": "Get one duty",
        "parameters": [
          {
            "$ref": "#/components/parameters/XRequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/DutyId"
          }
        ],
        "responses": {
          "200": {
            "description": "Duty found.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/XRequestId"
              },
              "ETag": {
                "$ref": "#/components/headers/ETag"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DutyEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Invalid duty id.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Duty not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Duties"
        ],
        "summary": "Update a duty",
        "parameters": [
          {
            "$ref": "#/components/parameters/XRequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/DutyId"
          },
          {
            "$ref": "#/components/parameters/IfMatchHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DutyInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Duty updated.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/XRequestId"
              },
              "ETag": {
                "$ref": "#/components/headers/ETag"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DutyEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Invalid id, input, or If-Match header.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Duty not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "412": {
            "description": "Duty changed since the client loaded it.",
            "headers": {
              "X-Request-Id": {
                "$ref": "#/components/headers/XRequestId"
              },
              "ETag": {
                "$ref": "#/components/headers/ETag"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PreconditionFailedEnvelope"
                }
              }
            }
          },
          "428": {
            "description": "If-Match header required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Write rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Duties"
        ],
        "summary": "Delete a duty",
        "parameters": [
          {
            "$ref": "#/components/parameters/XRequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/DutyId"
          }
        ],
        "responses": {
          "204": {
            "description": "Duty deleted."
          },
          "400": {
            "description": "Invalid duty id.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Duty not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Write rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "DutyId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Positive integer duty identifier expressed as a string in JSON payloads.",
        "schema": {
          "type": "string",
          "pattern": "^[1-9]\\d*$"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Pagination page size. If repeated, the first value is used.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "required": false,
        "description": "Pagination offset. If repeated, the first value is used.",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "DutyNameFilter": {
        "name": "name",
        "in": "query",
        "required": false,
        "description": "Simple case-insensitive duty-name filter. Surrounding whitespace is trimmed, repeated values use the first item, and `%` or `_` are treated as plain text.",
        "schema": {
          "type": "string",
          "maxLength": 256
        }
      },
      "XRequestIdHeader": {
        "name": "X-Request-Id",
        "in": "header",
        "required": false,
        "description": "Optional request correlation id. If omitted, the backend generates one.",
        "schema": {
          "type": "string"
        }
      },
      "IfMatchHeader": {
        "name": "If-Match",
        "in": "header",
        "required": true,
        "description": "Duty concurrency token in the format \"duty-<id>-v<version>\".",
        "schema": {
          "type": "string",
          "pattern": "^\"duty-[1-9]\\d*-v[1-9]\\d*\"$"
        }
      }
    },
    "headers": {
      "ETag": {
        "description": "Optimistic-concurrency token for a duty resource.",
        "schema": {
          "type": "string",
          "example": "\"duty-1-v2\""
        }
      },
      "XRequestId": {
        "description": "Request correlation id echoed by the backend.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Duty": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "1"
          },
          "name": {
            "type": "string",
            "maxLength": 256,
            "example": "Prepare sprint review"
          }
        }
      },
      "DutyInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 256,
            "example": "Prepare sprint review"
          }
        },
        "description": "Request body for create and update. Extra fields are ignored by backend validation. Names are trimmed and treated as plain text."
      },
      "DutyListPage": {
        "type": "object",
        "required": [
          "items",
          "total",
          "limit",
          "offset",
          "nextOffset"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Duty"
            }
          },
          "total": {
            "type": "integer",
            "example": 2
          },
          "limit": {
            "type": "integer",
            "example": 50
          },
          "offset": {
            "type": "integer",
            "example": 0
          },
          "nextOffset": {
            "type": [
              "integer",
              "null"
            ],
            "example": null
          }
        }
      },
      "DutyEnvelope": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Duty"
          }
        }
      },
      "DutyListPageEnvelope": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/DutyListPage"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "database",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "database": {
            "type": "string",
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "required": [
          "code",
          "message",
          "requestId"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string",
            "example": "Duty name is required."
          },
          "requestId": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      },
      "PreconditionFailedEnvelope": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message",
              "requestId",
              "details"
            ],
            "properties": {
              "code": {
                "type": "string",
                "example": "PRECONDITION_FAILED"
              },
              "message": {
                "type": "string",
                "example": "Duty has changed since you opened it. The latest duty has been loaded."
              },
              "requestId": {
                "type": "string"
              },
              "details": {
                "type": "object",
                "required": [
                  "latestDuty"
                ],
                "properties": {
                  "latestDuty": {
                    "$ref": "#/components/schemas/Duty"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
